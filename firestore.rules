rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerUid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid || isAdmin();
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid || isAdmin();
    }
    function ownerUidUnchanged() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == request.auth.uid || isAdmin();
    }
    function ownerUidNotModified() {
      return !('ownerUid' in request.resource.data) || request.resource.data.ownerUid == resource.data.ownerUid || isAdmin();
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "IekQHWYb1Ja2S7JB62th04pJkyZ2" ||
        request.auth.token.email == "beatriz@aidea.es" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.uid == "IekQHWYb1Ja2S7JB62th04pJkyZ2" ||
        request.auth.token.email == "beatriz@aidea.es" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin')
      );
    }
    
    function isCompanyAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'company_admin'
      );
    }
    
    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }
    
    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'role', 'createdAt', 'updatedAt', 'companyId', 'companyName', 'isAnonymous', 'assignedFields']) &&
             request.resource.data.uid is string &&
             request.resource.data.email is string &&
             request.resource.data.role in ['free', 'pending', 'subscription', 'enterprise', 'admin', 'company_admin'] &&
             request.resource.data.createdAt is timestamp &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp) &&
             (!('isAnonymous' in request.resource.data) || request.resource.data.isAnonymous is bool) &&
             (!('companyId' in request.resource.data) || request.resource.data.companyId is string) &&
             (!('companyName' in request.resource.data) || request.resource.data.companyName is string) &&
             (!('assignedFields' in request.resource.data) || request.resource.data.assignedFields is list);
    }

    function isValidCard() {
      return hasRequiredFields(['id', 'ownerUid', 'identity', 'status', 'createdAt', 'updatedAt']) &&
             request.resource.data.id is string &&
             request.resource.data.ownerUid is string &&
             request.resource.data.status in ['active', 'inactive'] &&
             (!('isAnonymous' in request.resource.data) || request.resource.data.isAnonymous is bool) &&
             (!('ownerRole' in request.resource.data) || request.resource.data.ownerRole is string) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp &&
             request.resource.data.identity is map &&
             request.resource.data.identity.keys().hasAll(['firstName', 'lastName']);
    }

    function isValidOrder() {
      return hasRequiredFields(['id', 'userId', 'cardId', 'status', 'shippingAddress', 'createdAt']) &&
             request.resource.data.id is string &&
             request.resource.data.userId is string &&
             request.resource.data.cardId is string &&
             request.resource.data.status in ['pending', 'confirmed', 'paid', 'shipped'] &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.shippingAddress is map &&
             request.resource.data.shippingAddress.keys().hasAll(['fullName', 'street', 'city', 'province', 'zip', 'country']);
    }

    function isValidProduct() {
      return hasRequiredFields(['id', 'name', 'price', 'createdAt']) &&
             request.resource.data.id is string &&
             request.resource.data.name is string &&
             request.resource.data.price is number &&
             (!('imageUrl' in request.resource.data) || request.resource.data.imageUrl is string) &&
             (!('features' in request.resource.data) || request.resource.data.features is string) &&
             (!('colors' in request.resource.data) || request.resource.data.colors is string) &&
             (!('datasheetUrl' in request.resource.data) || request.resource.data.datasheetUrl is string) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidCustomField() {
      return hasRequiredFields(['id', 'label', 'type']) &&
             request.resource.data.id is string &&
             request.resource.data.label is string &&
             request.resource.data.type in ['text', 'url', 'email', 'phone'] &&
             (!('icon' in request.resource.data) || request.resource.data.icon is string);
    }

    function isValidFieldTemplate() {
      return hasRequiredFields(['sector', 'name', 'icon', 'fields']) &&
             request.resource.data.sector is string &&
             request.resource.data.name is string &&
             request.resource.data.icon is string &&
             request.resource.data.fields is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (isCompanyAdmin() && resource.data.companyId == getUserCompanyId());
      allow create: if isAuthenticated() && 
                    (isOwner(userId) || isAdmin()) && 
                    isValidUser() && 
                    uidUnchanged();
      allow update: if isAuthenticated() && 
                    (isOwner(userId) || isAdmin()) && 
                    isValidUser() && 
                    uidNotModified();
      allow delete: if isAdmin();
    }

    match /cards/{cardId} {
      // Anyone can read an active card (for public sharing)
      allow read: if resource.data.status == 'active' || isDocOwner() || isAdmin() || (isCompanyAdmin() && get(/databases/$(database)/documents/users/$(resource.data.ownerUid)).data.companyId == getUserCompanyId());
      allow list: if isAdmin() || (isAuthenticated() && request.query.limit == 1) || (isCompanyAdmin() && get(/databases/$(database)/documents/users/$(resource.data.ownerUid)).data.companyId == getUserCompanyId());
      allow create: if isAuthenticated() && 
                    (request.resource.data.ownerUid == request.auth.uid || isAdmin()) && 
                    isValidCard() && 
                    ownerUidUnchanged();
      allow update: if isAuthenticated() && 
                    (isDocOwner() || isAdmin() || (isCompanyAdmin() && get(/databases/$(database)/documents/users/$(resource.data.ownerUid)).data.companyId == getUserCompanyId())) && 
                    isValidCard() && 
                    ownerUidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt; // Immutable createdAt
      allow delete: if isDocOwner() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && 
                    (request.resource.data.userId == request.auth.uid || isAdmin()) && 
                    isValidOrder();
      allow update: if isAuthenticated() && 
                    (request.auth.uid == resource.data.userId || isAdmin()) && 
                    isValidOrder() &&
                    (request.resource.data.userId == resource.data.userId || isAdmin()) &&
                    (request.resource.data.createdAt == resource.data.createdAt || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct();
      allow update: if isAdmin() && isValidProduct() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /companies/{companyId} {
      allow read: if isAdmin() || (isCompanyAdmin() && companyId == getUserCompanyId());
      allow create: if isAdmin();
      allow update: if isAdmin() || (isCompanyAdmin() && companyId == getUserCompanyId());
      allow delete: if isAdmin();
    }

    match /customFields/{fieldId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidCustomField();
      allow update: if isAdmin() && isValidCustomField();
      allow delete: if isAdmin();
    }

    match /fieldTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin() && isValidFieldTemplate();
      allow update: if isSuperAdmin() && isValidFieldTemplate();
      allow delete: if isSuperAdmin();
    }

    match /fieldDefinitions/{fieldId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.token.email == 'beatriz@aidea.es' || 
         request.auth.uid == 'IekQHWYb1Ja2S7JB62th04pJkyZ2');
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
